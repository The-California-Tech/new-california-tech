    "probe-image-size": "7.2.3",
    "rimraf": "6.1.3",
    "sass": "1.97.3",
    "sharp": "0.34.5",
    "svelte": "5.53.6",
    "svelte-check": "4.4.4",
    "svelte-preprocess": "6.0.3",
    "tippy.js": "6.3.7",
    "to-vfile": "8.0.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "unocss": "66.6.2",
    "unocss-preset-scrollbar": "4.0.0",
    "vite": "7.3.1",
    "vite-imagetools": "10.0.0",
    "wrangler": "^4.69.0"
  },
  "dependencies": {
    "pino-pretty": "^13.1.3",
    "symbiont-cms": "github:guutz/symbiont-cms#v1.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "symbiont-cms"
    ]
  }
