    "@unocss/transformer-compile-class": "66.6.2",
    "@unocss/transformer-directives": "66.6.2",
    "@unocss/transformer-variant-group": "66.5.2",
    "axios": "^1.13.6",
    "bits-ui": "2.16.2",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "cross-env": "10.1.0",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.15.0",
    "fs-extra": "11.3.3",
    "globals": "17.3.0",
    "gray-matter": "4.0.3",
    "html-to-text": "9.0.5",
    "imagetools-core": "9.1.0",
    "katex": "0.16.33",
    "limax": "4.2.2",
    "lz-string": "1.5.0",
    "marked": "17.0.3",
    "marked-gfm-heading-id": "4.1.3",
    "marked-mangle": "1.1.12",
    "medium-zoom": "1.1.0",
    "npm-run-all": "4.1.5",
    "nprogress": "0.2.0",
    "pdf-to-img": "^5.0.0",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.0",
