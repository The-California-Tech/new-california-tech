# Example Environment Configuration for California Tech + Symbiont Integration

# ============================================================================
# REQUIRED FOR CLIENT: Supabase Public Configuration
# ============================================================================
# These are safe to expose in the browser (public keys)
# Get from: Supabase Dashboard → Project Settings → API
VITE_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================================================
# REQUIRED FOR SYNC: Server-Only Secrets
# ============================================================================
# Notion API token with access to your database
# Get from: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role key (admin access for sync operations)
# Get from: Supabase Dashboard → Project Settings → API (service_role key)
# ⚠️ KEEP THIS SECRET - never expose in client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret for authenticating scheduled sync jobs
CRON_SECRET=your-random-secret-here
